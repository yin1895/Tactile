#!/bin/sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
if [ -n "${TACTILE_MACOS_WORKFLOW_DIR:-}" ]; then
  workflow_dir=$TACTILE_MACOS_WORKFLOW_DIR
elif [ -f "$script_dir/../scripts/macos_interface.py" ]; then
  workflow_dir=$(CDPATH= cd -- "$script_dir/.." && pwd)
else
  workflow_dir=$(CDPATH= cd -- "$script_dir/../macos-app-workflow" && pwd)
fi

case "${1:-}" in
  doctor|run-adapter|eval-suite|trace-replay|plan-log|profile-app|catalog-actions|artifact-dir|--help|-h)
    system_python=${TACTILE_MACOS_SYSTEM_PYTHON:-python3}
    exec "$system_python" "$workflow_dir/scripts/macos_interface.py" "$@"
    ;;
esac

exec "$workflow_dir/bin/tactile-macos-python" "$workflow_dir/scripts/macos_interface.py" "$@"
